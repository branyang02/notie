{
    "name": "notie-markdown",
    "private": false,
    "description": "A simple markdown note-taking app with live executable and editable code blocks.",
    "version": "1.4.2",
    "main": "./dist/index.cjs.js",
    "module": "dist/index.es.js",
    "types": "dist/index.d.ts",
    "homepage": "https://notie-markdown.vercel.app",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "require": "./dist/index.cjs.js",
            "default": "./dist/index.es.js"
        }
    },
    "sideEffects": [
        "**/*.css",
        "./dist/index.es.js",
        "./dist/index.cjs.js"
    ],
    "files": [
        "dist",
        "!dist/**/*.map"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/branyang02/notie.git"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "test": "vitest run",
        "benchmark": "tsx scripts/benchmark-notie.tsx",
        "format": "prettier --write .",
        "preview": "vite preview"
    },
    "dependencies": {
        "@codemirror/language": "^6.10.2",
        "@codemirror/state": "^6.4.1",
        "@shikijs/langs": "^4.0.2",
        "@shikijs/themes": "^4.0.2",
        "@uiw/react-codemirror": "^4.23.0",
        "bootstrap": "^5.3.3",
        "codemirror-shiki": "^0.3.0",
        "evergreen-ui": "^7.1.9",
        "github-slugger": "^2.0.0",
        "katex": "^0.16.22",
        "react-markdown": "^9.0.1",
        "rehype-katex": "^7.0.0",
        "rehype-raw": "^7.0.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.0",
        "remark-math": "^6.0.0",
        "shiki": "^4.0.2"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@types/node": "^22.1.0",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@typescript-eslint/eslint-plugin": "^7.15.0",
        "@typescript-eslint/parser": "^7.15.0",
        "@vitejs/plugin-react": "^4.3.1",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-react-refresh": "^0.4.7",
        "jsdom": "^29.1.1",
        "prettier": "^3.3.3",
        "prettier-plugin-organize-imports": "^4.0.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tsx": "^4.21.0",
        "typescript": "^5.2.2",
        "vite": "^5.3.4",
        "vite-plugin-css-injected-by-js": "^3.5.1",
        "vite-plugin-dts": "^4.0.0-beta.2",
        "vitest": "^4.1.5"
    }
}
